---
import readingTime from 'reading-time';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';
import { createClient } from '@/lib/supabase';
import type { Post } from '@/types';

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
const supabase = createClient(Astro.cookies);

let query = supabase
  .from('posts')
  .select('*')
  .eq('published', true)
  .order('pub_date', { ascending: false });

if (q) {
  query = query.or(`title.ilike.%${q}%,description.ilike.%${q}%`);
}

const { data } = await query;
const posts = (data ?? []) as Post[];
const minutesOf = (content: string) => Math.max(1, Math.round(readingTime(content).minutes));
---
<BaseLayout title="Blog" description="Artigos sobre desenvolvimento, arquitetura e engenharia de software.">
  <section class="top">
    <p class="eyebrow">{posts.length} artigo{posts.length === 1 ? '' : 's'}{q ? ` para "${q}"` : ''}</p>
    <h1>Blog</h1>
    <p class="sub">Notas técnicas, decisões de arquitetura e o que aprendo construindo software.</p>

    <form class="searchbox" method="get">
      <Icon name="search" size={18} />
      <input name="q" type="search" value={q} placeholder="Buscar artigos..." autocomplete="off" aria-label="Buscar artigos" />
    </form>
  </section>

  <section class="grid">
    {posts.length === 0 && (
      <p class="empty">
        {q ? `Nenhum resultado para "${q}".` : 'Ainda não há posts publicados.'}
      </p>
    )}
    {posts.map((p) => (
      <PostCard
        slug={p.slug}
        title={p.title}
        description={p.description}
        pubDate={new Date(p.pub_date)}
        tags={p.tags}
        minutes={minutesOf(p.content)}
      />
    ))}
  </section>

  <style>
    .top { padding: 3rem 0 1.5rem; max-width: 60ch; }
    h1 { font-size: 2.6rem; margin: 0.8rem 0 0.6rem; }
    .sub { color: var(--text-dim); font-size: 1.1rem; }
    .searchbox {
      display: flex; align-items: center; gap: 0.6rem; margin-top: 1.8rem;
      padding: 0.7rem 1rem; border: 1px solid var(--border); border-radius: 11px;
      background: var(--surface); color: var(--text-dim); transition: border-color 0.2s;
    }
    .searchbox:focus-within { border-color: var(--accent); }
    .searchbox input { flex: 1; background: none; border: none; color: var(--text); font-size: 1rem; outline: none; }
    .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; padding: 1.5rem 0 2rem; }
    .empty { color: var(--text-dim); grid-column: 1 / -1; }
    @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
