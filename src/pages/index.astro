---
import readingTime from 'reading-time';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Signature from '@/components/Signature.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/consts';
import { href } from '@/utils';
import { createClient } from '@/lib/supabase';
import type { Post } from '@/types';

const supabase = createClient(Astro.cookies);
const { data: posts } = await supabase
  .from('posts')
  .select('*')
  .eq('published', true)
  .order('pub_date', { ascending: false })
  .limit(4);

const recent = (posts ?? []) as Post[];
const minutesOf = (content: string) => Math.max(1, Math.round(readingTime(content).minutes));

const stack = ['C# / .NET', 'Node.js', 'React', 'TypeScript', 'SQL Server', 'Docker'];
---
<BaseLayout>
  <section class="hero rise">
    <div class="intro">
      <p class="eyebrow">{SITE.role} · {SITE.location}</p>
      <h1>Olá, sou <span class="hl">{SITE.author.split(' ')[0]}</span>.</h1>
      <p class="pitch">{SITE.tagline}</p>
      <div class="cta">
        <a href={href('/blog')} class="btn primary">Ler o blog <Icon name="arrow" size={16} /></a>
        <a href={href('/sobre')} class="btn ghost">Sobre mim</a>
      </div>
      <div class="sig"><Signature size={2.2} /></div>
    </div>

    <div class="avatar-wrap">
      <img src="/avatar.jpeg" alt={SITE.author} class="avatar" width="280" height="280" />
      <div class="ring" aria-hidden="true"></div>
    </div>
  </section>

  <section class="stack">
    <p class="eyebrow">Stack principal</p>
    <ul class="chips">
      {stack.map((s) => <li class="chip mono">{s}</li>)}
    </ul>
  </section>

  <section class="recent">
    <div class="sec-head">
      <h2>Últimos artigos</h2>
      <a href={href('/blog')} class="all">ver todos <Icon name="arrow" size={15} /></a>
    </div>
    {recent.length === 0 ? (
      <p class="empty">Ainda não há posts. <a href="/admin">Crie o primeiro →</a></p>
    ) : (
      <div class="grid">
        {recent.map((p, i) => (
          <PostCard
            slug={p.slug}
            title={p.title}
            description={p.description}
            pubDate={new Date(p.pub_date)}
            tags={p.tags}
            minutes={minutesOf(p.content)}
            featured={i === 0}
          />
        ))}
      </div>
    )}
  </section>

  <style>
    .hero {
      display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center;
      padding: 4rem 0 3rem;
    }
    .eyebrow { margin-bottom: 1rem; }
    h1 { font-size: clamp(2.4rem, 6vw, 4rem); }
    .hl { color: var(--accent); }
    .pitch { font-size: 1.3rem; color: var(--text-dim); max-width: 32ch; margin-top: 1.2rem; line-height: 1.5; }
    .cta { display: flex; gap: 0.8rem; margin-top: 2rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.7rem 1.3rem;
      border-radius: 10px; font-weight: 500; font-size: 0.95rem; transition: all 0.18s;
    }
    .primary { background: var(--accent); color: #fff; }
    .primary:hover { background: var(--accent-strong); color: #fff; transform: translateY(-2px); }
    .ghost { border: 1px solid var(--border); color: var(--text); }
    .ghost:hover { border-color: var(--accent); color: var(--accent); }
    .sig { margin-top: 2.2rem; opacity: 0.85; }

    .avatar-wrap { position: relative; width: 280px; height: 280px; }
    .avatar {
      width: 100%; height: 100%; object-fit: cover; border-radius: 50%;
      border: 1px solid var(--border); background: var(--surface); position: relative; z-index: 2;
    }
    .ring {
      position: absolute; inset: -10px; border-radius: 50%; z-index: 1;
      background: conic-gradient(from 180deg, var(--accent), var(--warm), var(--accent));
      filter: blur(28px); opacity: 0.35;
    }

    .stack { padding: 1.5rem 0 2rem; }
    .chips { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; list-style: none; padding: 0; }
    .chip {
      font-size: 0.82rem; padding: 0.4rem 0.8rem; border: 1px solid var(--border);
      border-radius: 8px; background: var(--surface); color: var(--text-dim);
    }

    .recent { padding: 2rem 0; }
    .sec-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.8rem; }
    .sec-head h2 { font-size: 1.8rem; }
    .all { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.9rem; color: var(--accent); }
    .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; }
    .grid > :global(.feat) { grid-column: 1 / -1; }
    .empty { color: var(--text-dim); }

    @media (max-width: 760px) {
      .hero { grid-template-columns: 1fr; text-align: left; }
      .avatar-wrap { width: 180px; height: 180px; order: -1; }
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
