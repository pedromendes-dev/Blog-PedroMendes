---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createClient } from '@/lib/supabase';

let error = '';
let fields = {
  title: '', slug: '', description: '', tags: '', pub_date: '', published: false, content: '',
};

const SLUG_RE = /^[a-z0-9]+(-[a-z0-9]+)*$/;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();

  fields = {
    title:       ((data.get('title')       as string) ?? '').trim(),
    slug:        ((data.get('slug')        as string) ?? '').trim(),
    description: ((data.get('description') as string) ?? '').trim(),
    content:     ((data.get('content')     as string) ?? '').trim(),
    tags:        ((data.get('tags')        as string) ?? '').trim(),
    pub_date:    ((data.get('pub_date')    as string) ?? '').trim(),
    published:   data.get('published') === 'on',
  };

  if      (!fields.title)                    error = 'O título é obrigatório.';
  else if (!fields.slug)                     error = 'O slug é obrigatório.';
  else if (!SLUG_RE.test(fields.slug))       error = 'Slug inválido. Use apenas letras minúsculas, números e hífens (ex: meu-post).';
  else if (!fields.description)              error = 'A descrição é obrigatória.';
  else if (!fields.content)                  error = 'O conteúdo não pode estar vazio.';

  if (!error) {
    const pub_date = fields.pub_date
      ? new Date(fields.pub_date + 'T12:00:00.000Z').toISOString()
      : new Date().toISOString();

    const tags = fields.tags.split(',').map((t) => t.trim()).filter(Boolean);

    const supabase = createClient(Astro.cookies);
    const { error: err } = await supabase.from('posts').insert({
      title: fields.title, slug: fields.slug, description: fields.description,
      content: fields.content, tags, published: fields.published, pub_date,
    });

    if (err) {
      error = err.message.includes('unique')
        ? 'Este slug já existe. Escolha outro.'
        : `Erro ao salvar: ${err.message}`;
    } else {
      return Astro.redirect('/admin/posts');
    }
  }
}

const today = new Date().toISOString().slice(0, 10);
---
<AdminLayout title="Novo post">
  <div class="page-header">
    <h1 class="page-title">Novo post</h1>
    <a href="/admin/posts" class="back-link">← Voltar</a>
  </div>

  {error && <div class="error" role="alert">{error}</div>}

  <form method="post" class="post-form" novalidate>
    <div class="row">
      <div class="field full">
        <label for="title">Título <span class="req">*</span></label>
        <input type="text" id="title" name="title" value={fields.title} placeholder="Título do post" autocomplete="off" />
      </div>
    </div>

    <div class="row">
      <div class="field full">
        <label for="slug">
          Slug <span class="req">*</span>
          <span class="hint">gerado automaticamente a partir do título</span>
        </label>
        <input type="text" id="slug" name="slug" value={fields.slug} placeholder="meu-primeiro-post" autocomplete="off" spellcheck="false" />
      </div>
    </div>

    <div class="row">
      <div class="field full">
        <label for="description">Descrição <span class="req">*</span> <span class="hint">aparece nos cards e no SEO</span></label>
        <textarea id="description" name="description" rows="2" placeholder="Resumo breve do post...">{fields.description}</textarea>
      </div>
    </div>

    <div class="row cols">
      <div class="field">
        <label for="tags">Tags <span class="hint">separadas por vírgula</span></label>
        <input type="text" id="tags" name="tags" value={fields.tags} placeholder="dotnet, csharp, arquitetura" autocomplete="off" />
      </div>
      <div class="field">
        <label for="pub_date">Data de publicação</label>
        <input type="date" id="pub_date" name="pub_date" value={fields.pub_date || today} />
      </div>
    </div>

    <div class="field full">
      <label for="content">Conteúdo <span class="req">*</span> <span class="hint">Markdown</span></label>
      <textarea
        id="content"
        name="content"
        class="editor"
        rows="28"
        placeholder="# Título do post&#10;&#10;## Introdução&#10;&#10;Escreva aqui em Markdown..."
        spellcheck="false"
      >{fields.content}</textarea>
    </div>

    <div class="footer">
      <label class="toggle-pub">
        <input type="checkbox" name="published" id="published" checked={fields.published} />
        <span>Publicar agora</span>
      </label>
      <div class="btns">
        <a href="/admin/posts" class="btn-cancel">Cancelar</a>
        <button type="submit" class="btn-primary">Salvar post</button>
      </div>
    </div>
  </form>
</AdminLayout>

<script>
  const titleEl = document.getElementById('title') as HTMLInputElement;
  const slugEl  = document.getElementById('slug')  as HTMLInputElement;
  const form    = document.querySelector('form')   as HTMLFormElement;

  // Gera slug a partir do título
  let slugTouched = slugEl.value !== '';
  slugEl.addEventListener('input', () => { slugTouched = true; });
  titleEl.addEventListener('input', () => {
    if (slugTouched) return;
    slugEl.value = titleEl.value
      .toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
  });

  // Tab insere 2 espaços no editor
  document.getElementById('content')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key !== 'Tab') return;
    e.preventDefault();
    const el = e.target as HTMLTextAreaElement;
    const s = el.selectionStart, end = el.selectionEnd;
    el.value = el.value.slice(0, s) + '  ' + el.value.slice(end);
    el.selectionStart = el.selectionEnd = s + 2;
  });

  // Validação antes de submeter
  form.addEventListener('submit', (e) => {
    const title   = (document.getElementById('title')   as HTMLInputElement).value.trim();
    const slug    = (document.getElementById('slug')    as HTMLInputElement).value.trim();
    const content = (document.getElementById('content') as HTMLTextAreaElement).value.trim();
    const SLUG_RE = /^[a-z0-9]+(-[a-z0-9]+)*$/;

    let msg = '';
    if (!title)            msg = 'O título é obrigatório.';
    else if (!slug)        msg = 'O slug é obrigatório.';
    else if (!SLUG_RE.test(slug)) msg = 'Slug inválido. Use apenas letras minúsculas, números e hífens.';
    else if (!content)     msg = 'O conteúdo não pode estar vazio.';

    if (msg) {
      e.preventDefault();
      let box = document.querySelector<HTMLDivElement>('.error');
      if (!box) { box = document.createElement('div'); box.className = 'error'; box.setAttribute('role', 'alert'); form.before(box); }
      box.textContent = msg;
      box.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
</script>

<style>
  .back-link { color: var(--text-dim); font-size: 0.9rem; }
  .back-link:hover { color: var(--accent); }

  .error {
    background: rgba(229,62,62,0.1); border: 1px solid rgba(229,62,62,0.4);
    color: #fc8181; padding: 0.85rem 1.1rem; border-radius: 9px; margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .post-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .row { display: flex; gap: 1rem; }
  .cols { gap: 1.5rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; flex: 1; }
  .full { flex: 1; }

  label { font-size: 0.82rem; color: var(--text-dim); font-weight: 500; }
  .req { color: #fc8181; }
  .hint { font-weight: 400; opacity: 0.55; margin-left: 0.3rem; }

  input[type=text], input[type=date], textarea {
    padding: 0.7rem 0.9rem; background: var(--surface-2);
    border: 1px solid var(--border); border-radius: 9px; color: var(--text);
    font-size: 0.95rem; outline: none; transition: border-color 0.2s;
    font-family: inherit; width: 100%;
  }
  input:focus, textarea:focus { border-color: var(--accent); }
  textarea { resize: vertical; }

  .editor {
    font-family: var(--mono);
    font-size: 0.88rem;
    line-height: 1.65;
    background: #080c14;
    min-height: 420px;
    tab-size: 2;
  }

  .footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; gap: 1rem;
  }
  .toggle-pub { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; color: var(--text-dim); font-size: 0.9rem; }
  .toggle-pub input { width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent); }
  .btns { display: flex; gap: 0.75rem; }
  .btn-cancel {
    padding: 0.65rem 1.2rem; border: 1px solid var(--border); border-radius: 9px;
    color: var(--text-dim); font-size: 0.9rem; text-decoration: none; transition: all 0.15s;
  }
  .btn-cancel:hover { border-color: var(--text-dim); color: var(--text); }

  @media (max-width: 760px) { .cols { flex-direction: column; } }
</style>
