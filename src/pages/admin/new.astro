---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createClient } from '@/lib/supabase';

let error = '';
let saved = { title: '', slug: '', description: '', tags: '', pub_date: '', published: false, content: '' };

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const title = ((data.get('title') as string) ?? '').trim();
  const slug = ((data.get('slug') as string) ?? '').trim();
  const description = ((data.get('description') as string) ?? '').trim();
  const content = ((data.get('content') as string) ?? '').trim();
  const tagsRaw = ((data.get('tags') as string) ?? '').trim();
  const tags = tagsRaw.split(',').map((t) => t.trim()).filter(Boolean);
  const published = data.get('published') === 'on';
  const pub_date_raw = ((data.get('pub_date') as string) ?? '').trim() || new Date().toISOString().slice(0, 10);

  saved = { title, slug, description, tags: tagsRaw, pub_date: pub_date_raw, published, content };

  if (!title) error = 'O título é obrigatório.';
  else if (!slug) error = 'O slug é obrigatório.';
  else if (!description) error = 'A descrição é obrigatória.';
  else if (!content) error = 'O conteúdo não pode estar vazio.';
  else {
    let pub_date: string;
    try {
      pub_date = new Date(pub_date_raw + 'T12:00:00.000Z').toISOString();
    } catch {
      pub_date = new Date().toISOString();
    }

    const supabase = createClient(Astro.cookies);
    const { error: err } = await supabase.from('posts').insert({
      title, slug, description, content, tags, published, pub_date,
    });

    if (err) {
      error = err.message.includes('unique') ? 'Este slug já existe. Escolha outro.' : err.message;
    } else {
      return Astro.redirect('/admin/posts');
    }
  }
}

const today = new Date().toISOString().slice(0, 10);
const initialDate = saved.pub_date || today;
---
<AdminLayout title="Novo post">
  <div class="page-header">
    <h1 class="page-title">Novo post</h1>
    <a href="/admin/posts" class="back-link">← Voltar</a>
  </div>

  {error && <div class="error">{error}</div>}

  <form method="post" class="post-form" id="post-form">
    <div class="row">
      <div class="field full">
        <label for="title">Título *</label>
        <input type="text" id="title" name="title" required placeholder="Título do post" value={saved.title} />
      </div>
    </div>
    <div class="row">
      <div class="field full">
        <label for="slug">Slug * <span class="hint">URL amigável (ex: meu-primeiro-post)</span></label>
        <input type="text" id="slug" name="slug" required placeholder="meu-primeiro-post" pattern="[a-z0-9-]+" value={saved.slug} />
      </div>
    </div>
    <div class="row">
      <div class="field full">
        <label for="description">Descrição * <span class="hint">Aparece nos cards e no SEO</span></label>
        <textarea id="description" name="description" required rows="2" placeholder="Resumo do post...">{saved.description}</textarea>
      </div>
    </div>
    <div class="row cols">
      <div class="field">
        <label for="tags">Tags <span class="hint">Separadas por vírgula</span></label>
        <input type="text" id="tags" name="tags" placeholder="dotnet, arquitetura, csharp" value={saved.tags} />
      </div>
      <div class="field">
        <label for="pub_date">Data de publicação</label>
        <input type="date" id="pub_date" name="pub_date" value={initialDate} />
      </div>
    </div>

    <div class="field full">
      <label for="content">Conteúdo *</label>
      <div id="monaco-container"></div>
      <textarea id="content" name="content" style="display:none">{saved.content}</textarea>
    </div>

    <div class="footer">
      <label class="toggle-pub">
        <input type="checkbox" name="published" id="published" checked={saved.published} />
        <span>Publicar agora</span>
      </label>
      <div class="btns">
        <a href="/admin/posts" class="btn-cancel">Cancelar</a>
        <button type="submit" class="btn-primary">Salvar post</button>
      </div>
    </div>
  </form>
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js"></script>
<script>
  const titleInput = document.getElementById('title') as HTMLInputElement | null;
  const slugInput = document.getElementById('slug') as HTMLInputElement | null;
  const textarea = document.getElementById('content') as HTMLTextAreaElement;
  const form = document.getElementById('post-form') as HTMLFormElement;

  let slugEdited = !!slugInput?.value;
  slugInput?.addEventListener('input', () => { slugEdited = true; });
  titleInput?.addEventListener('input', () => {
    if (slugEdited || !slugInput) return;
    slugInput.value = titleInput.value
      .toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
  });

  declare const require: any;
  require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs' } });
  require(['vs/editor/editor.main'], function () {
    declare const monaco: any;
    const editor = monaco.editor.create(document.getElementById('monaco-container'), {
      value: textarea.value,
      language: 'markdown',
      theme: 'vs-dark',
      minimap: { enabled: false },
      wordWrap: 'on',
      lineNumbers: 'on',
      fontSize: 14,
      fontFamily: "'JetBrains Mono', 'Fira Code', monospace",
      scrollBeyondLastLine: false,
      automaticLayout: true,
    });

    editor.onDidChangeModelContent(() => {
      textarea.value = editor.getValue();
    });

    form.addEventListener('submit', (e) => {
      textarea.value = editor.getValue();
      if (!textarea.value.trim()) {
        e.preventDefault();
        const existing = document.querySelector('.error');
        const msg = 'O conteúdo não pode estar vazio.';
        if (existing) { existing.textContent = msg; }
        else {
          const div = document.createElement('div');
          div.className = 'error';
          div.textContent = msg;
          form.before(div);
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .back-link { color: var(--text-dim); font-size: 0.9rem; }
  .back-link:hover { color: var(--accent); }
  .error {
    background: rgba(229,62,62,0.1); border: 1px solid rgba(229,62,62,0.3);
    color: #fc8181; padding: 0.8rem 1rem; border-radius: 9px; margin-bottom: 1.5rem;
  }
  .post-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .row { display: flex; gap: 1rem; }
  .cols { gap: 1.5rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .full { flex: 1; }
  label { font-size: 0.82rem; color: var(--text-dim); font-weight: 500; }
  .hint { font-weight: 400; opacity: 0.6; }
  input[type=text], input[type=date], textarea {
    padding: 0.7rem 0.9rem; background: var(--surface-2);
    border: 1px solid var(--border); border-radius: 9px; color: var(--text);
    font-size: 0.95rem; outline: none; transition: border-color 0.2s;
    font-family: inherit; width: 100%;
  }
  input:focus, textarea:focus { border-color: var(--accent); }
  textarea { resize: vertical; }
  .footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; gap: 1rem;
  }
  .toggle-pub { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; color: var(--text-dim); font-size: 0.9rem; }
  .toggle-pub input { width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent); }
  .btns { display: flex; gap: 0.75rem; }
  .btn-cancel {
    padding: 0.65rem 1.2rem; border: 1px solid var(--border); border-radius: 9px;
    color: var(--text-dim); font-size: 0.9rem; text-decoration: none;
    transition: all 0.15s;
  }
  .btn-cancel:hover { border-color: var(--text-dim); color: var(--text); }
  #monaco-container {
    height: 500px;
    border: 1px solid var(--border);
    border-radius: 9px;
    overflow: hidden;
  }
  @media (max-width: 760px) { .cols { flex-direction: column; } }
</style>
