---
import readingTime from 'reading-time';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';
import { href } from '@/utils';
import { createClient } from '@/lib/supabase';
import type { Post } from '@/types';

const { tag } = Astro.params;
if (!tag) return Astro.redirect('/blog');

const supabase = createClient(Astro.cookies);
const { data } = await supabase
  .from('posts')
  .select('*')
  .eq('published', true)
  .contains('tags', [tag])
  .order('pub_date', { ascending: false });

const posts = (data ?? []) as Post[];
const minutesOf = (content: string) => Math.max(1, Math.round(readingTime(content).minutes));
---
<BaseLayout title={`#${tag}`} description={`Artigos sobre ${tag}.`}>
  <section class="top">
    <a href={href('/blog')} class="back mono"><Icon name="arrow" size={14} /> voltar ao blog</a>
    <p class="eyebrow">{posts.length} artigo{posts.length === 1 ? '' : 's'}</p>
    <h1>#{tag}</h1>
  </section>
  <section class="grid">
    {posts.length === 0 && <p class="empty">Nenhum post com esta tag.</p>}
    {posts.map((p) => (
      <PostCard
        slug={p.slug}
        title={p.title}
        description={p.description}
        pubDate={new Date(p.pub_date)}
        tags={p.tags}
        minutes={minutesOf(p.content)}
      />
    ))}
  </section>

  <style>
    .top { padding: 3rem 0 1.5rem; }
    .back { display: inline-flex; align-items: center; gap: 0.35rem; color: var(--text-dim); font-size: 0.8rem; }
    .back:hover { color: var(--accent); }
    .back :global(svg) { transform: rotate(180deg); }
    h1 { font-size: 2.6rem; margin: 0.6rem 0; color: var(--warm); }
    .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; padding: 1rem 0 2rem; }
    .empty { color: var(--text-dim); }
    @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
